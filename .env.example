# ──────────────────────────────────────────────────────────────────────────────
# FlowBit (Syncaura) — Environment Variables Example
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (used in config/axios.js and config/routes.js)
VITE_API_URL=http://localhost:5000

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Your GitHub OAuth App's Client ID
# Create one at: https://github.com/settings/developers → OAuth Apps → New OAuth App
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# The redirect URI registered in your GitHub OAuth App settings.
# Must match exactly what GitHub redirects to after authorization.
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback
